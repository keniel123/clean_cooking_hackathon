# Copy to .env and adjust. Every value has a working default for local dev.

DATABASE_URL=sqlite:///./survey.db

# console | twilio | africastalking
SMS_PROVIDER=console

# How bare local numbers (07...) are interpreted: KE or GB.
DEFAULT_COUNTRY=KE

# Expose POST /webhooks/simulate and /demo for local testing. Disable in production.
ENABLE_SIMULATOR=true

# Substituted into {utility} placeholders in survey texts (e.g. S0).
UTILITY_NAME=[UTILITY]

# Local timezone for the panel scheduler (send days, Sundays rule).
TIMEZONE=Africa/Nairobi

# GridCook API (apps/api) used by `survey respondent import-gridcook`.
# Use http://127.0.0.1:8000 when running apps/api locally.
GRIDCOOK_API_BASE=https://delft-api.flonat.com

# Twilio (UK testing) — see README "Gateway setup"
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_VALIDATE_SIGNATURE=false
PUBLIC_BASE_URL=

# Africa's Talking (Kenya production)
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=
AT_ENVIRONMENT=sandbox
